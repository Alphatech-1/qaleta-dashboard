---
export const prerender = false;

import Layout from "../layouts/DashboardLayout.astro";
import { supabase } from "../lib/supabase";

let mensaje = "";

// Detectar si estamos editando
const editId = Astro.url.searchParams.get("edit");
let gastoEditar = null;

if (editId) {
  const { data } = await supabase
    .from("gastos")
    .select("*")
    .eq("id", editId)
    .single();
  
  gastoEditar = data;
}

// POST
if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const deleteId = formData.get("deleteId");
  const updateId = formData.get("updateId");

  // ELIMINAR
  if (deleteId) {
    const { error } = await supabase
      .from("gastos")
      .delete()
      .eq("id", deleteId);

    if (error) {
      mensaje = error.message;
    } else {
      return Astro.redirect("/gastos");
    }
  }
  
  // EDITAR
  else if (updateId) {
    const categoria = formData.get("categoria")?.toString();
    const descripcion = formData.get("descripcion")?.toString();
    const monto = Number(formData.get("monto"));
    const fecha = formData.get("fecha")?.toString();

    const { error } = await supabase
      .from("gastos")
      .update({ categoria, descripcion, monto, fecha })
      .eq("id", updateId);

    if (error) {
      mensaje = error.message;
    } else {
      return Astro.redirect("/gastos");
    }
  }
  
  // CREAR
  else {
    const categoria = formData.get("categoria")?.toString();
    const descripcion = formData.get("descripcion")?.toString();
    const monto = Number(formData.get("monto"));
    const fecha = formData.get("fecha")?.toString();

    const { error } = await supabase
      .from("gastos")
      .insert([{ categoria, descripcion, monto, fecha }]);

    if (error) {
      mensaje = error.message;
    } else {
      return Astro.redirect("/gastos");
    }
  }
}

// Obtener gastos
const { data: gastos } = await supabase
  .from("gastos")
  .select("*")
  .order("fecha", { ascending: false });
  
// Calcular total de gastos
const totalGastos = gastos?.reduce((sum, g) => sum + g.monto, 0) || 0;

// Categorías con iconos
const categoriasIconos = {
  "Insumos": "🥩",
  "Gas": "🔥",
  "Bebidas": "🥤",
  "Personal": "👥",
  "Publicidad": "📢",
  "Otros": "📦"
};

// Función para obtener color por categoría
const getCategoriaColor = (categoria) => {
  const colores = {
    "Insumos": "bg-orange-100 text-orange-700",
    "Gas": "bg-red-100 text-red-700",
    "Bebidas": "bg-blue-100 text-blue-700",
    "Personal": "bg-purple-100 text-purple-700",
    "Publicidad": "bg-pink-100 text-pink-700",
    "Otros": "bg-gray-100 text-gray-700"
  };
  return colores[categoria] || "bg-gray-100 text-gray-700";
};
---

<Layout title="Control de gastos">
  <div class="space-y-8">
    <!-- Encabezado de sección -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-800 mb-2">🧾 Control de gastos</h1>
      <p class="text-gray-600">Administra todos los gastos del negocio</p>
    </div>

    <!-- Mensaje de error -->
    {mensaje && (
      <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-lg">
        <div class="flex items-center gap-2">
          <span class="text-xl">⚠️</span>
          <p class="font-medium">{mensaje}</p>
        </div>
      </div>
    )}

    <!-- Formulario de gastos -->
    <div class="bg-white rounded-2xl shadow-soft p-8 border border-gray-100">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 bg-gradient-to-br from-red-500 to-rose-600 rounded-xl flex items-center justify-center">
          <span class="text-white text-xl">
            {gastoEditar ? "✏️" : "➕"}
          </span>
        </div>
        <h2 class="text-2xl font-bold text-gray-800">
          {gastoEditar ? "Editar gasto" : "Nuevo gasto"}
        </h2>
      </div>

      <form method="POST" class="space-y-6">
        {gastoEditar && (
          <input type="hidden" name="updateId" value={gastoEditar.id} />
        )}

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Fecha -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">
              📅 Fecha
            </label>
            <input
              type="date"
              name="fecha"
              required
              value={gastoEditar?.fecha}
              class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none"
            />
          </div>

          <!-- Categoría -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">
              🏷️ Categoría
            </label>
            <select
              name="categoria"
              required
              class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none bg-white"
            >
              <option value="Insumos" selected={gastoEditar?.categoria === "Insumos"}>
                🥩 Insumos
              </option>
              <option value="Gas" selected={gastoEditar?.categoria === "Gas"}>
                🔥 Gas
              </option>
              <option value="Bebidas" selected={gastoEditar?.categoria === "Bebidas"}>
                🥤 Bebidas
              </option>
              <option value="Personal" selected={gastoEditar?.categoria === "Personal"}>
                👥 Personal
              </option>
              <option value="Publicidad" selected={gastoEditar?.categoria === "Publicidad"}>
                📢 Publicidad
              </option>
              <option value="Otros" selected={gastoEditar?.categoria === "Otros"}>
                📦 Otros
              </option>
            </select>
          </div>

          <!-- Descripción -->
          <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-gray-700 mb-2">
              📝 Descripción
            </label>
            <input
              type="text"
              name="descripcion"
              placeholder="Ej: Compra de pan para la semana"
              required
              value={gastoEditar?.descripcion}
              class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none"
            />
          </div>

          <!-- Monto -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">
              💲 Monto
            </label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500">S/</span>
              <input
                type="number"
                step="0.01"
                name="monto"
                placeholder="0.00"
                required
                value={gastoEditar?.monto}
                class="w-full pl-8 pr-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none"
              />
            </div>
          </div>
        </div>

        <!-- Botones -->
        <div class="flex gap-3 pt-4">
          <button
            type="submit"
            class="px-6 py-2.5 bg-gradient-to-r from-red-600 to-rose-600 text-white font-semibold rounded-xl hover:from-red-700 hover:to-rose-700 transition-all shadow-md hover:shadow-lg"
          >
            {gastoEditar ? "✓ Actualizar gasto" : "✓ Guardar gasto"}
          </button>
          
          {gastoEditar && (
            <a
              href="/gastos"
              class="px-6 py-2.5 bg-gray-500 text-white font-semibold rounded-xl hover:bg-gray-600 transition-all"
            >
              ✗ Cancelar
            </a>
          )}
        </div>
      </form>
    </div>

    <!-- Tabla de gastos -->
    <div class="bg-white rounded-2xl shadow-soft border border-gray-100 overflow-hidden">
      <div class="px-8 py-6 bg-gradient-to-r from-gray-50 to-white border-b border-gray-200">
        <div class="flex items-center justify-between flex-wrap gap-4">
          <div>
            <h2 class="text-2xl font-bold text-gray-800">📋 Historial de gastos</h2>
            <p class="text-sm text-gray-500 mt-1">Total de registros: {gastos?.length || 0}</p>
          </div>
          <div class="bg-red-50 px-6 py-3 rounded-xl">
            <p class="text-sm text-red-600 font-semibold">Total gastado</p>
            <p class="text-2xl font-bold text-red-700">S/ {totalGastos.toFixed(2)}</p>
          </div>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Fecha</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Categoría</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Descripción</th>
              <th class="px-6 py-4 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Monto</th>
              <th class="px-6 py-4 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {gastos?.length === 0 ? (
              <tr>
                <td colspan="5" class="px-6 py-12 text-center text-gray-500">
                  <div class="text-6xl mb-3">📭</div>
                  <p class="text-lg">No hay gastos registrados</p>
                  <p class="text-sm">Comienza agregando tu primer gasto</p>
                </td>
              </tr>
            ) : (
              gastos?.map((gasto) => (
                <tr key={gasto.id} class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-4 text-sm text-gray-700 font-medium">
                    {new Date(gasto.fecha).toLocaleDateString('es-PE')}
                  </td>
                  <td class="px-6 py-4">
                    <span class={`inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-medium ${getCategoriaColor(gasto.categoria)}`}>
                      <span>{categoriasIconos[gasto.categoria] || "📦"}</span>
                      {gasto.categoria}
                    </span>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-800">
                    {gasto.descripcion}
                  </td>
                  <td class="px-6 py-4 text-sm font-bold text-gray-900 text-right">
                    <span class="bg-red-50 text-red-700 px-3 py-1 rounded-lg">
                      S/ {gasto.monto.toFixed(2)}
                    </span>
                  </td>
                  <td class="px-6 py-4 text-center">
                    <div class="flex gap-2 justify-center">
                      <form method="GET" class="inline">
                        <input type="hidden" name="edit" value={gasto.id} />
                        <button
                          type="submit"
                          class="px-3 py-1.5 bg-blue-500 text-white text-sm rounded-lg hover:bg-blue-600 transition-colors flex items-center gap-1"
                          title="Editar"
                        >
                          ✏️ Editar
                        </button>
                      </form>
                      
                      <form method="POST" class="inline" onsubmit="return confirm('¿Estás seguro de eliminar este gasto?')">
                        <input type="hidden" name="deleteId" value={gasto.id} />
                        <button
                          type="submit"
                          class="px-3 py-1.5 bg-red-500 text-white text-sm rounded-lg hover:bg-red-600 transition-colors flex items-center gap-1"
                          title="Eliminar"
                        >
                          🗑️ Eliminar
                        </button>
                      </form>
                    </div>
                  </td>
                 </tr>
              ))
            )}
          </tbody>
          
          {gastos && gastos.length > 0 && (
            <tfoot class="bg-gray-50 border-t border-gray-200">
              <tr>
                <td colspan="3" class="px-6 py-4 text-right font-bold text-gray-800">Total general:</td>
                <td class="px-6 py-4 text-right">
                  <span class="text-lg font-bold text-red-700">
                    S/ {totalGastos.toFixed(2)}
                  </span>
                </td>
                <td></td>
              </tr>
            </tfoot>
          )}
        </table>
      </div>
    </div>

    <!-- Resumen por categorías -->
    {gastos && gastos.length > 0 && (
      <div class="bg-white rounded-2xl shadow-soft p-6 border border-gray-100">
        <h3 class="text-lg font-bold text-gray-800 mb-4">📊 Resumen por categorías</h3>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          {Object.entries(
            gastos.reduce((acc, gasto) => {
              acc[gasto.categoria] = (acc[gasto.categoria] || 0) + gasto.monto;
              return acc;
            }, {})
          ).map(([categoria, total]) => (
            <div key={categoria} class="bg-gray-50 rounded-xl p-4 text-center hover:shadow-md transition-shadow">
              <div class="text-3xl mb-2">{categoriasIconos[categoria] || "📦"}</div>
              <p class="text-sm font-semibold text-gray-700">{categoria}</p>
              <p class="text-lg font-bold text-red-600">S/ {total.toFixed(2)}</p>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</Layout>

<style>
  /* Animaciones adicionales */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .space-y-8 > * {
    animation: fadeIn 0.3s ease-out;
  }
</style>