{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/clientes/?$",
			"dest": "_render"
		},
		{
			"src": "^/creditos/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/?$",
			"dest": "_render"
		},
		{
			"src": "^/gastos/?$",
			"dest": "_render"
		},
		{
			"src": "^/inventario/?$",
			"dest": "_render"
		},
		{
			"src": "^/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/productos/?$",
			"dest": "_render"
		},
		{
			"src": "^/productos-fiados/?$",
			"dest": "_render"
		},
		{
			"src": "^/reportes/?$",
			"dest": "_render"
		},
		{
			"src": "^/test/?$",
			"dest": "_render"
		},
		{
			"src": "^/ventas/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}