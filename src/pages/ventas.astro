---
export const prerender = false;

import Layout from "../layouts/DashboardLayout.astro";
import { supabase } from "../lib/supabase";

const { data: productos } = await supabase
  .from("productos")
  .select("*")
  .eq("activo", true);

// Obtener clientes para créditos
const { data: clientes } = await supabase
  .from("clientes")
  .select("*")
  .order("nombre");

let mensaje = "";

const editId = Astro.url.searchParams.get("edit");
let ventaEditar = null;

if (editId) {
  const { data } = await supabase
    .from("ventas")
    .select("*")
    .eq("id", editId)
    .single();
  
  ventaEditar = data;
}

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const deleteId = formData.get("deleteId");
  const updateId = formData.get("updateId");

  // ELIMINAR
  if (deleteId) {
    const { error } = await supabase
      .from("ventas")
      .delete()
      .eq("id", deleteId);

    if (!error) {
      return Astro.redirect("/ventas");
    }
  }
  
  // EDITAR
  else if (updateId) {
    const fecha = formData.get("fecha")?.toString();
    const producto = formData.get("producto")?.toString();
    const cantidad = Number(formData.get("cantidad"));
    const precio = Number(formData.get("precio"));
    const total = cantidad * precio;
    const tipoPago = formData.get("tipo_pago")?.toString();
    const clienteId = formData.get("cliente_id")?.toString();

    const { error } = await supabase
      .from("ventas")
      .update({ fecha, producto, cantidad, precio, total, tipo_pago: tipoPago, cliente_id: clienteId || null })
      .eq("id", updateId);

    if (!error) {
      return Astro.redirect("/ventas");
    }
  }
  
  // CREAR
  else {
    const fecha = formData.get("fecha")?.toString();
    const producto = formData.get("producto")?.toString();
    const cantidad = Number(formData.get("cantidad"));
    const precio = Number(formData.get("precio"));
    const total = cantidad * precio;
    const tipoPago = formData.get("tipo_pago")?.toString();
    const clienteId = formData.get("cliente_id")?.toString();

    // Si es crédito, también crear registro en tabla creditos
    if (tipoPago === "credito" && clienteId) {
      // Insertar en ventas primero
      const { data: nuevaVenta, error: ventaError } = await supabase
        .from("ventas")
        .insert([{ fecha, producto, cantidad, precio, total, tipo_pago: tipoPago, cliente_id: clienteId }])
        .select();
      
      if (!ventaError && nuevaVenta) {
        // Crear registro en créditos
        await supabase
          .from("creditos")
          .insert([{
            cliente_id: parseInt(clienteId),
            fecha,
            producto,
            cantidad,
            precio_unitario: precio,
            total,
            pagado: 0,
            saldo: total,
            estado: "pendiente",
            afecta_caja: false
          }]);
      }
      return Astro.redirect("/ventas");
    } else {
      // Venta normal en efectivo
      const { error } = await supabase
        .from("ventas")
        .insert([{ fecha, producto, cantidad, precio, total, tipo_pago: tipoPago, cliente_id: null }]);

      if (!error) {
        return Astro.redirect("/ventas");
      }
    }
  }
}

const { data: ventas } = await supabase
  .from("ventas")
  .select("*")
  .order("fecha", { ascending: false });
---

<Layout title="Ventas">
  <div class="space-y-6 sm:space-y-8">
    <!-- Encabezado de sección -->
    <div class="mb-6 sm:mb-8">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-800 mb-2">💰 Ventas</h1>
      <p class="text-sm sm:text-base text-gray-600">Gestiona todas las ventas de choripanes</p>
    </div>

    <!-- Formulario de ventas -->
    <div class="bg-white rounded-xl sm:rounded-2xl shadow-soft p-4 sm:p-6 md:p-8 border border-gray-100">
      <div class="flex items-center gap-3 mb-4 sm:mb-6">
        <div class={`w-8 h-8 sm:w-10 sm:h-10 rounded-xl flex items-center justify-center ${
          ventaEditar 
            ? 'bg-gradient-to-br from-blue-500 to-indigo-600' 
            : 'bg-gradient-to-br from-green-500 to-emerald-600'
        }`}>
          <span class="text-white text-lg sm:text-xl">
            {ventaEditar ? "✏️" : "➕"}
          </span>
        </div>
        <h2 class="text-xl sm:text-2xl font-bold text-gray-800">
          {ventaEditar ? "Editar venta" : "Nueva venta"}
        </h2>
      </div>

      <form method="POST" class="space-y-4 sm:space-y-6" id="ventaForm">
        {ventaEditar && (
          <input type="hidden" name="updateId" value={ventaEditar.id} />
        )}

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
          <!-- Fecha -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">
              📅 Fecha
            </label>
            <input
              type="date"
              name="fecha"
              required
              value={ventaEditar?.fecha}
              class="w-full px-3 sm:px-4 py-2 sm:py-2.5 border border-gray-300 rounded-lg sm:rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all outline-none text-sm sm:text-base"
            />
          </div>

          <!-- Producto -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">
              🥩 Producto
            </label>
            <select
              name="producto"
              id="producto"
              required
              class="w-full px-3 sm:px-4 py-2 sm:py-2.5 border border-gray-300 rounded-lg sm:rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all outline-none bg-white text-sm sm:text-base"
            >
              <option value="">Seleccionar producto</option>
              {productos?.map((producto) => (
                <option 
                  key={producto.id}
                  value={producto.nombre}
                  data-precio={producto.precio}
                  selected={ventaEditar?.producto === producto.nombre}
                >
                  {producto.nombre} - S/ {producto.precio.toFixed(2)}
                </option>
              ))}
            </select>
            {(!productos || productos.length === 0) && (
              <p class="text-xs text-orange-600 mt-1">
                ⚠️ No hay productos activos. Crea productos en Inventario.
              </p>
            )}
          </div>

          <!-- Cantidad -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">
              🔢 Cantidad
            </label>
            <input
              type="number"
              name="cantidad"
              id="cantidad"
              min="1"
              step="1"
              required
              value={ventaEditar?.cantidad || 1}
              class="w-full px-3 sm:px-4 py-2 sm:py-2.5 border border-gray-300 rounded-lg sm:rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all outline-none text-sm sm:text-base"
            />
          </div>

          <!-- Precio -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">
              💲 Precio unitario
            </label>
            <div class="relative">
              <span class="absolute left-3 sm:left-4 top-1/2 -translate-y-1/2 text-gray-500 text-sm sm:text-base">S/</span>
              <input
                id="precio"
                type="number"
                step="0.01"
                name="precio"
                required
                value={ventaEditar?.precio || ""}
                class="w-full pl-7 sm:pl-8 pr-3 sm:pr-4 py-2 sm:py-2.5 border border-gray-300 rounded-lg sm:rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all outline-none text-sm sm:text-base"
              />
            </div>
          </div>
        </div>

        <!-- Tipo de pago -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">
              💳 Tipo de pago
            </label>
            <select
              name="tipo_pago"
              id="tipo_pago"
              required
              class="w-full px-3 sm:px-4 py-2 sm:py-2.5 border border-gray-300 rounded-lg sm:rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all outline-none bg-white text-sm sm:text-base"
            >
              <option value="efectivo" selected={ventaEditar?.tipo_pago === "efectivo" || !ventaEditar}>
                💵 Efectivo (afecta caja)
              </option>
              <option value="credito" selected={ventaEditar?.tipo_pago === "credito"}>
                📝 Crédito (no afecta caja)
              </option>
            </select>
            <p class="text-xs text-gray-500 mt-1" id="tipoPagoInfo">
              Los créditos se registrarán como cuenta por cobrar
            </p>
          </div>

          <!-- Cliente (solo para créditos) -->
          <div id="clienteContainer" class={!ventaEditar?.cliente_id && ventaEditar?.tipo_pago !== "credito" ? "hidden" : ""}>
            <label class="block text-sm font-semibold text-gray-700 mb-2">
              👤 Cliente
            </label>
            <select
              name="cliente_id"
              id="cliente_id"
              class="w-full px-3 sm:px-4 py-2 sm:py-2.5 border border-gray-300 rounded-lg sm:rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all outline-none bg-white text-sm sm:text-base"
            >
              <option value="">Seleccionar cliente</option>
              {clientes?.map((cliente) => (
                <option 
                  key={cliente.id} 
                  value={cliente.id}
                  selected={ventaEditar?.cliente_id === cliente.id}
                >
                  {cliente.nombre} {cliente.telefono ? `- ${cliente.telefono}` : ''}
                </option>
              ))}
            </select>
            <div class="flex items-center justify-between mt-1">
              <p class="text-xs text-orange-600">
                ⚠️ Requerido para ventas a crédito
              </p>
              <a href="/clientes" class="text-xs text-blue-600 hover:underline">+ Nuevo cliente</a>
            </div>
          </div>
        </div>

        <!-- Total en tiempo real -->
        <div class="bg-gray-50 rounded-lg sm:rounded-xl p-3 sm:p-4 border border-gray-200">
          <div class="flex items-center justify-between">
            <span class="text-sm sm:text-base font-semibold text-gray-700">💰 Total de la venta:</span>
            <span id="totalPreview" class="text-xl sm:text-2xl font-bold text-green-600">
              S/ 0.00
            </span>
          </div>
        </div>

        <!-- Botones -->
        <div class="flex flex-col sm:flex-row gap-3 pt-2 sm:pt-4">
          <button
            type="submit"
            class="px-4 sm:px-6 py-2.5 sm:py-2.5 bg-gradient-to-r from-green-600 to-emerald-600 text-white font-semibold rounded-lg sm:rounded-xl hover:from-green-700 hover:to-emerald-700 transition-all shadow-md hover:shadow-lg text-sm sm:text-base"
          >
            {ventaEditar ? "✓ Actualizar venta" : "✓ Guardar venta"}
          </button>
          
          {ventaEditar && (
            <a
              href="/ventas"
              class="px-4 sm:px-6 py-2.5 bg-gray-500 text-white font-semibold rounded-lg sm:rounded-xl hover:bg-gray-600 transition-all text-center text-sm sm:text-base"
            >
              ✗ Cancelar
            </a>
          )}
        </div>
      </form>
    </div>

    <!-- Tabla de ventas -->
    <div class="bg-white rounded-xl sm:rounded-2xl shadow-soft border border-gray-100 overflow-hidden">
      <div class="px-4 sm:px-6 md:px-8 py-4 sm:py-6 bg-gradient-to-r from-gray-50 to-white border-b border-gray-200">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
          <div>
            <h2 class="text-xl sm:text-2xl font-bold text-gray-800">📋 Historial de ventas</h2>
            <p class="text-xs sm:text-sm text-gray-500 mt-1">Total de registros: {ventas?.length || 0}</p>
          </div>
          <div class="flex gap-2">
            <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded">💵 Efectivo</span>
            <span class="text-xs bg-yellow-100 text-yellow-700 px-2 py-1 rounded">📝 Crédito</span>
          </div>
        </div>
      </div>

      <!-- Versión Desktop - Tabla tradicional -->
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-4 lg:px-6 py-3 lg:py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Fecha</th>
              <th class="px-4 lg:px-6 py-3 lg:py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Producto</th>
              <th class="px-4 lg:px-6 py-3 lg:py-4 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Cantidad</th>
              <th class="px-4 lg:px-6 py-3 lg:py-4 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Precio unit.</th>
              <th class="px-4 lg:px-6 py-3 lg:py-4 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Total</th>
              <th class="px-4 lg:px-6 py-3 lg:py-4 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Tipo</th>
              <th class="px-4 lg:px-6 py-3 lg:py-4 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {ventas?.length === 0 ? (
              <tr>
                <td colspan="7" class="px-6 py-12 text-center text-gray-500">
                  <div class="text-6xl mb-3">📭</div>
                  <p class="text-lg">No hay ventas registradas</p>
                  <p class="text-sm">Comienza agregando tu primera venta</p>
                </td>
              </tr>
            ) : (
              ventas?.map((venta) => (
                <tr key={venta.id} class="hover:bg-gray-50 transition-colors">
                  <td class="px-4 lg:px-6 py-3 lg:py-4 text-sm text-gray-700 font-medium">
                    {new Date(venta.fecha).toLocaleDateString('es-PE')}
                  </td>
                  <td class="px-4 lg:px-6 py-3 lg:py-4 text-sm text-gray-800 font-semibold">
                    {venta.producto}
                  </td>
                  <td class="px-4 lg:px-6 py-3 lg:py-4 text-sm text-gray-700 text-center">
                    {venta.cantidad}
                  </td>
                  <td class="px-4 lg:px-6 py-3 lg:py-4 text-sm text-gray-700 text-right">
                    S/ {venta.precio.toFixed(2)}
                  </td>
                  <td class="px-4 lg:px-6 py-3 lg:py-4 text-sm font-bold text-gray-900 text-right">
                    <span class="bg-green-100 text-green-700 px-2 lg:px-3 py-1 rounded-lg text-xs lg:text-sm">
                      S/ {venta.total.toFixed(2)}
                    </span>
                  </td>
                  <td class="px-4 lg:px-6 py-3 lg:py-4 text-center">
                    {venta.tipo_pago === 'credito' ? (
                      <span class="inline-flex items-center gap-1 px-2 py-1 bg-yellow-100 text-yellow-700 rounded-lg text-xs">
                        📝 Crédito
                      </span>
                    ) : (
                      <span class="inline-flex items-center gap-1 px-2 py-1 bg-green-100 text-green-700 rounded-lg text-xs">
                        💵 Efectivo
                      </span>
                    )}
                  </td>
                  <td class="px-4 lg:px-6 py-3 lg:py-4 text-center">
                    <div class="flex gap-2 justify-center">
                      <form method="GET" class="inline">
                        <input type="hidden" name="edit" value={venta.id} />
                        <button
                          type="submit"
                          class="px-2 lg:px-3 py-1 lg:py-1.5 bg-blue-500 text-white text-xs lg:text-sm rounded-lg hover:bg-blue-600 transition-colors flex items-center gap-1"
                          title="Editar"
                        >
                          ✏️ <span class="hidden sm:inline">Editar</span>
                        </button>
                      </form>
                      
                      <form method="POST" class="inline" onsubmit="return confirm('¿Estás seguro de eliminar esta venta?')">
                        <input type="hidden" name="deleteId" value={venta.id} />
                        <button
                          type="submit"
                          class="px-2 lg:px-3 py-1 lg:py-1.5 bg-red-500 text-white text-xs lg:text-sm rounded-lg hover:bg-red-600 transition-colors flex items-center gap-1"
                          title="Eliminar"
                        >
                          🗑️ <span class="hidden sm:inline">Eliminar</span>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              ))
            )}
          </tbody>
          
          {ventas && ventas.length > 0 && (
            <tfoot class="bg-gray-50 border-t border-gray-200">
              <tr class="bg-gray-50">
                <td colspan="4" class="px-4 lg:px-6 py-3 lg:py-4 text-right font-bold text-gray-800">Total general:</td>
                <td class="px-4 lg:px-6 py-3 lg:py-4 text-right font-bold text-green-700">
                  S/ {ventas.reduce((sum, v) => sum + v.total, 0).toFixed(2)}
                </td>
                <td colspan="2"></td>
              </tr>
              <tr class="bg-gray-100">
                <td colspan="4" class="px-4 lg:px-6 py-3 lg:py-4 text-right font-bold text-gray-800">💵 Total efectivo:</td>
                <td class="px-4 lg:px-6 py-3 lg:py-4 text-right font-bold text-green-700">
                  S/ {ventas.filter(v => v.tipo_pago === 'efectivo').reduce((sum, v) => sum + v.total, 0).toFixed(2)}
                </td>
                <td colspan="2"></td>
              </tr>
              <tr class="bg-gray-100">
                <td colspan="4" class="px-4 lg:px-6 py-3 lg:py-4 text-right font-bold text-gray-800">📝 Total créditos:</td>
                <td class="px-4 lg:px-6 py-3 lg:py-4 text-right font-bold text-yellow-700">
                  S/ {ventas.filter(v => v.tipo_pago === 'credito').reduce((sum, v) => sum + v.total, 0).toFixed(2)}
                </td>
                <td colspan="2"></td>
              </tr>
            </tfoot>
          )}
        </table>
      </div>

      <!-- Versión Móvil - Cards -->
      <div class="md:hidden divide-y divide-gray-100">
        {ventas?.length === 0 ? (
          <div class="px-6 py-12 text-center text-gray-500">
            <div class="text-6xl mb-3">📭</div>
            <p class="text-lg">No hay ventas registradas</p>
            <p class="text-sm">Comienza agregando tu primera venta</p>
          </div>
        ) : (
          ventas?.map((venta) => (
            <div key={venta.id} class="p-4 hover:bg-gray-50 transition-colors">
              <div class="flex justify-between items-start mb-2">
                <div>
                  <div class="flex items-center gap-2">
                    <p class="font-bold text-gray-800 text-base">{venta.producto}</p>
                    {venta.tipo_pago === 'credito' ? (
                      <span class="text-xs bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded">📝 Crédito</span>
                    ) : (
                      <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded">💵 Efectivo</span>
                    )}
                  </div>
                  <p class="text-xs text-gray-500 mt-1">
                    📅 {new Date(venta.fecha).toLocaleDateString('es-PE')}
                  </p>
                </div>
                <div class="bg-green-100 text-green-700 px-3 py-1 rounded-lg font-bold text-sm">
                  S/ {venta.total.toFixed(2)}
                </div>
              </div>
              
              <div class="grid grid-cols-2 gap-2 mt-3 text-sm">
                <div>
                  <span class="text-gray-500">🔢 Cantidad:</span>
                  <p class="font-semibold text-gray-800">{venta.cantidad}</p>
                </div>
                <div>
                  <span class="text-gray-500">💲 Precio unit.:</span>
                  <p class="font-semibold text-gray-800">S/ {venta.precio.toFixed(2)}</p>
                </div>
              </div>
              
              <div class="flex gap-2 mt-4">
                <form method="GET" class="flex-1">
                  <input type="hidden" name="edit" value={venta.id} />
                  <button
                    type="submit"
                    class="w-full px-3 py-2 bg-blue-500 text-white text-sm rounded-lg hover:bg-blue-600 transition-colors flex items-center justify-center gap-1"
                  >
                    ✏️ Editar
                  </button>
                </form>
                
                <form method="POST" class="flex-1" onsubmit="return confirm('¿Estás seguro de eliminar esta venta?')">
                  <input type="hidden" name="deleteId" value={venta.id} />
                  <button
                    type="submit"
                    class="w-full px-3 py-2 bg-red-500 text-white text-sm rounded-lg hover:bg-red-600 transition-colors flex items-center justify-center gap-1"
                  >
                    🗑️ Eliminar
                  </button>
                </form>
              </div>
            </div>
          ))
        )}
        
        {ventas && ventas.length > 0 && (
          <div class="p-4 bg-gray-50 border-t border-gray-200 space-y-2">
            <div class="flex justify-between items-center">
              <span class="font-bold text-gray-800">Total general:</span>
              <span class="text-lg font-bold text-green-700">
                S/ {ventas.reduce((sum, v) => sum + v.total, 0).toFixed(2)}
              </span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-gray-600">💵 Efectivo:</span>
              <span class="font-semibold text-green-600">
                S/ {ventas.filter(v => v.tipo_pago === 'efectivo').reduce((sum, v) => sum + v.total, 0).toFixed(2)}
              </span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-gray-600">📝 Créditos:</span>
              <span class="font-semibold text-yellow-600">
                S/ {ventas.filter(v => v.tipo_pago === 'credito').reduce((sum, v) => sum + v.total, 0).toFixed(2)}
              </span>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Animaciones adicionales */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .space-y-6 > *,
  .space-y-8 > * {
    animation: fadeIn 0.3s ease-out;
  }
</style>

<script>
  const productoSelect = document.getElementById("producto");
  const precioInput = document.getElementById("precio");
  const cantidadInput = document.getElementById("cantidad");
  const totalPreview = document.getElementById("totalPreview");
  const tipoPago = document.getElementById("tipo_pago");
  const clienteContainer = document.getElementById("clienteContainer");
  const clienteSelect = document.getElementById("cliente_id");

  function actualizarTotal() {
    const precio = parseFloat(precioInput?.value) || 0;
    const cantidad = parseInt(cantidadInput?.value) || 0;
    const total = precio * cantidad;
    
    if (totalPreview) {
      totalPreview.textContent = `S/ ${total.toFixed(2)}`;
    }
  }

  // Mostrar/ocultar selector de cliente según tipo de pago
  function toggleClienteField() {
    if (tipoPago?.value === 'credito') {
      clienteContainer?.classList.remove('hidden');
      // Hacer requerido el cliente para créditos
      if (clienteSelect) clienteSelect.required = true;
    } else {
      clienteContainer?.classList.add('hidden');
      if (clienteSelect) clienteSelect.required = false;
    }
  }

  // Auto-completar precio al seleccionar producto
  productoSelect?.addEventListener("change", (e) => {
    const option = e.target.selectedOptions[0];
    const precioData = option?.dataset?.precio;
    
    if (precioData && precioInput) {
      precioInput.value = precioData;
      actualizarTotal();
    }
  });

  // Actualizar total al cambiar cantidad o precio
  precioInput?.addEventListener("input", actualizarTotal);
  cantidadInput?.addEventListener("input", actualizarTotal);
  
  // Evento para tipo de pago
  tipoPago?.addEventListener("change", toggleClienteField);
  
  // Calcular total inicial si hay valores
  actualizarTotal();
  
  // Inicializar estado del campo cliente
  toggleClienteField();
</script>