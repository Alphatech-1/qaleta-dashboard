---
import Layout from "../layouts/DashboardLayout.astro";
import { supabase } from "../lib/supabase";

// Obtener parámetros de filtro desde la URL
const urlParams = Astro.url.searchParams;
const fechaInicio = urlParams.get("fecha_inicio") || "";
const fechaFin = urlParams.get("fecha_fin") || "";
const tipoReporte = urlParams.get("tipo") || "diario"; // diario, semanal, mensual
const categoriaFiltro = urlParams.get("categoria") || "";
const productoFiltro = urlParams.get("producto") || "";

// Fechas por defecto
const hoy = new Date().toISOString().split("T")[0];
const hace7Dias = new Date();
hace7Dias.setDate(hace7Dias.getDate() - 7);
const fechaDefaultInicio = fechaInicio || hace7Dias.toISOString().split("T")[0];
const fechaDefaultFin = fechaFin || hoy;

// CONSULTAS CON FILTROS DE FECHA
let ventasQuery = supabase.from("ventas").select("*");
let gastosQuery = supabase.from("gastos").select("*");
let pagosCreditosQuery = supabase.from("pagos_creditos").select("*");
let pagosPrestamosQuery = supabase.from("pagos_prestamos").select("*, prestamos(cliente_id, prestamos(cliente_id))");

if (fechaDefaultInicio) {
  ventasQuery = ventasQuery.gte("fecha", fechaDefaultInicio);
  gastosQuery = gastosQuery.gte("fecha", fechaDefaultInicio);
  pagosCreditosQuery = pagosCreditosQuery.gte("fecha", fechaDefaultInicio);
  pagosPrestamosQuery = pagosPrestamosQuery.gte("fecha", fechaDefaultInicio);
}
if (fechaDefaultFin) {
  ventasQuery = ventasQuery.lte("fecha", fechaDefaultFin);
  gastosQuery = gastosQuery.lte("fecha", fechaDefaultFin);
  pagosCreditosQuery = pagosCreditosQuery.lte("fecha", fechaDefaultFin);
  pagosPrestamosQuery = pagosPrestamosQuery.lte("fecha", fechaDefaultFin);
}

const [{ data: ventas }, { data: gastos }, { data: pagosCreditos }, { data: pagosPrestamos }] = await Promise.all([
  ventasQuery,
  gastosQuery,
  pagosCreditosQuery,
  pagosPrestamosQuery
]);

// Filtrar por categoría si se especifica
let gastosFiltrados = gastos || [];
if (categoriaFiltro) {
  gastosFiltrados = gastosFiltrados.filter(g => g.categoria === categoriaFiltro);
}

// Filtrar por producto si se especifica
let ventasFiltradas = ventas || [];
if (productoFiltro) {
  ventasFiltradas = ventasFiltradas.filter(v => v.producto?.toLowerCase().includes(productoFiltro.toLowerCase()));
}

// TOTALES
const totalVentas = ventasFiltradas.reduce((acc, v) => acc + Number(v.total), 0);
const totalGastos = gastosFiltrados.reduce((acc, g) => acc + Number(g.monto), 0);
const totalPagosCreditos = pagosCreditos?.reduce((acc, p) => acc + Number(p.monto), 0) || 0;
const totalPagosPrestamos = pagosPrestamos?.reduce((acc, p) => acc + Number(p.monto), 0) || 0;

const totalIngresos = totalVentas + totalPagosCreditos + totalPagosPrestamos;
const totalEgresos = totalGastos;
const gananciaNeta = totalIngresos - totalEgresos;
const margenGanancia = totalIngresos > 0 ? (gananciaNeta / totalIngresos) * 100 : 0;

// Datos para gráficos según el tipo de reporte
let datosGrafico = [];
if (tipoReporte === "diario") {
  // Agrupar por día
  const diasMap = new Map();
  const fechaActual = new Date(fechaDefaultInicio);
  const fechaFinDate = new Date(fechaDefaultFin);
  
  for (let d = new Date(fechaActual); d <= fechaFinDate; d.setDate(d.getDate() + 1)) {
    const fechaStr = d.toISOString().split("T")[0];
    diasMap.set(fechaStr, { fecha: fechaStr, ventas: 0, gastos: 0, ingresos: 0 });
  }
  
  ventasFiltradas.forEach(v => {
    if (diasMap.has(v.fecha)) {
      diasMap.get(v.fecha).ventas += Number(v.total);
    }
  });
  
  gastosFiltrados.forEach(g => {
    if (diasMap.has(g.fecha)) {
      diasMap.get(g.fecha).gastos += Number(g.monto);
    }
  });
  
  pagosCreditos?.forEach(p => {
    if (diasMap.has(p.fecha)) {
      diasMap.get(p.fecha).ingresos += Number(p.monto);
    }
  });
  
  pagosPrestamos?.forEach(p => {
    if (diasMap.has(p.fecha)) {
      diasMap.get(p.fecha).ingresos += Number(p.monto);
    }
  });
  
  datosGrafico = Array.from(diasMap.values());
} else if (tipoReporte === "semanal") {
  // Agrupar por semana
  const semanasMap = new Map();
  
  const getWeekNumber = (date) => {
    const d = new Date(date);
    d.setHours(0, 0, 0, 0);
    d.setDate(d.getDate() + 4 - (d.getDay() || 7));
    const yearStart = new Date(d.getFullYear(), 0, 1);
    const weekNo = Math.ceil(((d - yearStart) / 86400000 + 1) / 7);
    return `${d.getFullYear()}-S${weekNo}`;
  };
  
  ventasFiltradas.forEach(v => {
    const semana = getWeekNumber(v.fecha);
    if (!semanasMap.has(semana)) semanasMap.set(semana, { semana, ventas: 0, gastos: 0 });
    semanasMap.get(semana).ventas += Number(v.total);
  });
  
  gastosFiltrados.forEach(g => {
    const semana = getWeekNumber(g.fecha);
    if (!semanasMap.has(semana)) semanasMap.set(semana, { semana, ventas: 0, gastos: 0 });
    semanasMap.get(semana).gastos += Number(g.monto);
  });
  
  datosGrafico = Array.from(semanasMap.values());
} else {
  // Agrupar por mes
  const mesesMap = new Map();
  
  ventasFiltradas.forEach(v => {
    const mes = v.fecha.substring(0, 7);
    if (!mesesMap.has(mes)) mesesMap.set(mes, { mes, ventas: 0, gastos: 0 });
    mesesMap.get(mes).ventas += Number(v.total);
  });
  
  gastosFiltrados.forEach(g => {
    const mes = g.fecha.substring(0, 7);
    if (!mesesMap.has(mes)) mesesMap.set(mes, { mes, ventas: 0, gastos: 0 });
    mesesMap.get(mes).gastos += Number(g.monto);
  });
  
  datosGrafico = Array.from(mesesMap.values());
}

// PRODUCTOS MÁS VENDIDOS
const productosMap = {};
ventasFiltradas.forEach((venta) => {
  const nombre = venta.producto;
  if (!productosMap[nombre]) {
    productosMap[nombre] = 0;
  }
  productosMap[nombre] += venta.cantidad;
});

const topProductos = Object.entries(productosMap)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);

// GASTOS POR CATEGORÍA
const gastosPorCategoria = {};
gastosFiltrados.forEach((gasto) => {
  const categoria = gasto.categoria;
  if (!gastosPorCategoria[categoria]) {
    gastosPorCategoria[categoria] = 0;
  }
  gastosPorCategoria[categoria] += Number(gasto.monto);
});

const topCategorias = Object.entries(gastosPorCategoria)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);

// Obtener categorías únicas para el filtro
const categoriasUnicas = [...new Set(gastos?.map(g => g.categoria) || [])];

// Calcular ticket promedio
const ticketPromedio = ventasFiltradas.length > 0 ? totalVentas / ventasFiltradas.length : 0;
const totalProductosVendidos = ventasFiltradas.reduce((acc, v) => acc + v.cantidad, 0);

// FUNCIONES DE UTILIDAD
const formatFecha = (fecha) => {
  if (!fecha) return '';
  return new Date(fecha).toLocaleDateString('es-PE');
};

const categoriaIconos = {
  "Insumos": { icono: "🥩", color: "bg-orange-500" },
  "Gas": { icono: "🔥", color: "bg-red-500" },
  "Bebidas": { icono: "🥤", color: "bg-blue-500" },
  "Personal": { icono: "👥", color: "bg-purple-500" },
  "Publicidad": { icono: "📢", color: "bg-pink-500" },
  "Prestamos": { icono: "🏦", color: "bg-indigo-500" },
  "Otros": { icono: "📦", color: "bg-gray-500" }
};
---

<Layout title="Reportes">
  <div class="space-y-6 sm:space-y-8">
    <!-- Encabezado -->
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-800 mb-2">📈 Reportes y análisis</h1>
      <p class="text-sm sm:text-base text-gray-600">Visualiza el rendimiento financiero de tu negocio</p>
    </div>

    <!-- Panel de Filtros -->
    <div class="bg-white rounded-2xl shadow-soft p-6 border border-gray-100">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
          <span class="text-xl">🔍</span>
          <h3 class="text-lg font-bold text-gray-800">Filtrar reportes</h3>
        </div>
        {(fechaInicio || fechaFin || categoriaFiltro || productoFiltro) && (
          <a href="/reportes" class="text-sm text-red-600 hover:text-red-700 font-semibold">
            ✖️ Limpiar filtros
          </a>
        )}
      </div>

      <form method="GET" class="space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">
              📅 Fecha desde
            </label>
            <input
              type="date"
              name="fecha_inicio"
              value={fechaDefaultInicio}
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">
              📅 Fecha hasta
            </label>
            <input
              type="date"
              name="fecha_fin"
              value={fechaDefaultFin}
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">
              📊 Tipo de reporte
            </label>
            <select
              name="tipo"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none"
            >
              <option value="diario" selected={tipoReporte === "diario"}>📅 Diario</option>
              <option value="semanal" selected={tipoReporte === "semanal"}>📆 Semanal</option>
              <option value="mensual" selected={tipoReporte === "mensual"}>📊 Mensual</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">
              🏷️ Categoría de gasto
            </label>
            <select
              name="categoria"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none"
            >
              <option value="">Todas las categorías</option>
              {categoriasUnicas.map(cat => (
                <option value={cat} selected={categoriaFiltro === cat}>{cat}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">
              🔎 Buscar producto
            </label>
            <input
              type="text"
              name="producto"
              placeholder="Ej: Pan, Carne..."
              value={productoFiltro}
              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>
        </div>

        <div class="flex gap-3 pt-2">
          <button
            type="submit"
            class="px-6 py-2 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-semibold rounded-lg hover:shadow-lg transition-all"
          >
            🔍 Aplicar filtros
          </button>
          <span class="px-6 py-2 bg-gray-100 text-gray-700 font-semibold rounded-lg">
            📊 Período: {formatFecha(fechaDefaultInicio)} - {formatFecha(fechaDefaultFin)}
          </span>
        </div>
      </form>
    </div>

    <!-- Cards de resumen -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5">
      <div class="bg-gradient-to-br from-green-500 to-emerald-600 rounded-xl p-5 text-white shadow-lg">
        <div class="flex items-center justify-between mb-3">
          <p class="text-sm opacity-90">💰 Ingresos totales</p>
          <span class="text-2xl">📈</span>
        </div>
        <h2 class="text-2xl font-bold">S/ {totalIngresos.toFixed(2)}</h2>
        <div class="text-xs opacity-75 mt-2">
          Ventas: S/ {totalVentas.toFixed(2)} | 
          Pagos: S/ {(totalPagosCreditos + totalPagosPrestamos).toFixed(2)}
        </div>
      </div>

      <div class="bg-gradient-to-br from-red-500 to-rose-600 rounded-xl p-5 text-white shadow-lg">
        <div class="flex items-center justify-between mb-3">
          <p class="text-sm opacity-90">📤 Egresos totales</p>
          <span class="text-2xl">📉</span>
        </div>
        <h2 class="text-2xl font-bold">S/ {totalEgresos.toFixed(2)}</h2>
        <p class="text-xs opacity-75 mt-2">{gastosFiltrados.length} gastos registrados</p>
      </div>

      <div class={`bg-gradient-to-br rounded-xl p-5 text-white shadow-lg ${gananciaNeta >= 0 ? 'from-blue-500 to-indigo-600' : 'from-orange-500 to-red-600'}`}>
        <div class="flex items-center justify-between mb-3">
          <p class="text-sm opacity-90">💵 Ganancia neta</p>
          <span class="text-2xl">🎯</span>
        </div>
        <h2 class="text-2xl font-bold">S/ {gananciaNeta.toFixed(2)}</h2>
        <p class="text-xs opacity-75 mt-2">Margen: {margenGanancia.toFixed(1)}%</p>
      </div>

      <div class="bg-gradient-to-br from-purple-500 to-pink-600 rounded-xl p-5 text-white shadow-lg">
        <div class="flex items-center justify-between mb-3">
          <p class="text-sm opacity-90">🎫 Ticket promedio</p>
          <span class="text-2xl">💰</span>
        </div>
        <h2 class="text-2xl font-bold">S/ {ticketPromedio.toFixed(2)}</h2>
        <p class="text-xs opacity-75 mt-2">Por venta</p>
      </div>
    </div>

    <!-- Gráfico de evolución -->
    <div class="bg-white rounded-xl shadow-soft p-6 border border-gray-100">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="text-xl font-bold text-gray-800">📊 Evolución {tipoReporte === 'diario' ? 'diaria' : tipoReporte === 'semanal' ? 'semanal' : 'mensual'}</h2>
          <p class="text-xs text-gray-500 mt-1">Ingresos vs Gastos</p>
        </div>
        <span class="text-2xl">📈</span>
      </div>
      
      {datosGrafico.length === 0 ? (
        <div class="text-center py-12 text-gray-500">
          <div class="text-6xl mb-3">📭</div>
          <p>No hay datos en el período seleccionado</p>
        </div>
      ) : (
        <div class="space-y-4">
          {datosGrafico.map((item, index) => {
            const maxValor = Math.max(...datosGrafico.map(d => Math.max(d.ventas || 0, d.gastos || 0)), 1);
            const alturaIngresos = ((item.ventas + (item.ingresos || 0)) / maxValor) * 100;
            const alturaGastos = (item.gastos / maxValor) * 100;
            const label = tipoReporte === 'diario' ? item.fecha : (item.semana || item.mes);
            
            return (
              <div key={index}>
                <div class="flex justify-between text-sm mb-1">
                  <span class="font-medium text-gray-600">{label}</span>
                  <div class="flex gap-3">
                    <span class="text-green-600">+S/ {(item.ventas + (item.ingresos || 0)).toFixed(2)}</span>
                    <span class="text-red-600">-S/ {item.gastos.toFixed(2)}</span>
                  </div>
                </div>
                <div class="h-8 bg-gray-100 rounded-lg overflow-hidden flex">
                  <div class="bg-green-500 h-full flex items-center justify-end px-2 text-xs text-white font-medium" 
                       style="width: ${alturaIngresos}%">
                    {alturaIngresos > 15 ? `S/ ${(item.ventas + (item.ingresos || 0)).toFixed(0)}` : ''}
                  </div>
                  <div class="bg-red-500 h-full flex items-center justify-start px-2 text-xs text-white font-medium" 
                       style="width: ${alturaGastos}%">
                    {alturaGastos > 15 ? `S/ ${item.gastos.toFixed(0)}` : ''}
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>

    <!-- Top Productos y Top Gastos -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
      <!-- Productos más vendidos -->
      <div class="bg-white rounded-xl shadow-soft border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 bg-gradient-to-r from-orange-50 to-amber-50 border-b border-gray-200">
          <div class="flex items-center gap-2">
            <span class="text-2xl">🌭</span>
            <h2 class="text-xl font-bold text-gray-800">Top productos más vendidos</h2>
          </div>
          <p class="text-xs text-gray-500 mt-1">Total unidades: {totalProductosVendidos}</p>
        </div>
        
        <div class="divide-y divide-gray-100">
          {topProductos.length === 0 ? (
            <div class="p-8 text-center text-gray-500">
              <div class="text-4xl mb-2">📭</div>
              <p>No hay ventas en el período seleccionado</p>
            </div>
          ) : (
            topProductos.map(([producto, cantidad], index) => {
              const porcentaje = (cantidad / totalProductosVendidos) * 100;
              return (
                <div key={producto} class="p-5 hover:bg-gray-50 transition-colors">
                  <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center gap-3">
                      <div class={`w-7 h-7 rounded-full flex items-center justify-center text-white text-sm font-bold ${
                        index === 0 ? 'bg-yellow-500' : index === 1 ? 'bg-gray-400' : index === 2 ? 'bg-orange-600' : 'bg-gray-300'
                      }`}>
                        #{index + 1}
                      </div>
                      <span class="font-semibold text-gray-800">{producto}</span>
                    </div>
                    <span class="text-lg font-bold text-green-600">{cantidad} uds.</span>
                  </div>
                  <div class="h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div class="h-full bg-gradient-to-r from-green-500 to-emerald-500 rounded-full" style="width: ${porcentaje}%"></div>
                  </div>
                  <p class="text-xs text-gray-500 mt-1">{porcentaje.toFixed(1)}% del total</p>
                </div>
              );
            })
          )}
        </div>
      </div>

      <!-- Gastos por categoría -->
      <div class="bg-white rounded-xl shadow-soft border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 bg-gradient-to-r from-red-50 to-rose-50 border-b border-gray-200">
          <div class="flex items-center gap-2">
            <span class="text-2xl">📊</span>
            <h2 class="text-xl font-bold text-gray-800">Distribución de gastos</h2>
          </div>
          <p class="text-xs text-gray-500 mt-1">Por categoría</p>
        </div>
        
        <div class="divide-y divide-gray-100">
          {topCategorias.length === 0 ? (
            <div class="p-8 text-center text-gray-500">
              <div class="text-4xl mb-2">📭</div>
              <p>No hay gastos en el período seleccionado</p>
            </div>
          ) : (
            topCategorias.map(([categoria, monto]) => {
              const porcentaje = (monto / totalGastos) * 100;
              const { icono, color } = categoriaIconos[categoria] || { icono: "📦", color: "bg-gray-500" };
              return (
                <div key={categoria} class="p-5 hover:bg-gray-50 transition-colors">
                  <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center gap-3">
                      <div class={`w-8 h-8 ${color} rounded-lg flex items-center justify-center text-white`}>
                        <span>{icono}</span>
                      </div>
                      <span class="font-semibold text-gray-800">{categoria}</span>
                    </div>
                    <span class="text-lg font-bold text-red-600">S/ {monto.toFixed(2)}</span>
                  </div>
                  <div class="h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div class={`h-full rounded-full ${color}`} style="width: ${porcentaje}%"></div>
                  </div>
                  <p class="text-xs text-gray-500 mt-1">{porcentaje.toFixed(1)}% del total</p>
                </div>
              );
            })
          )}
        </div>
        
        {topCategorias.length > 0 && (
          <div class="px-6 py-3 bg-gray-50 border-t border-gray-200">
            <div class="flex justify-between items-center">
              <span class="text-sm font-semibold text-gray-700">Total gastos</span>
              <span class="text-lg font-bold text-red-600">S/ {totalGastos.toFixed(2)}</span>
            </div>
          </div>
        )}
      </div>
    </div>

    {/* Tabla detallada de transacciones */}
    <div class="bg-white rounded-xl shadow-soft border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
        <h2 class="text-xl font-bold text-gray-800">📋 Detalle de transacciones</h2>
        <p class="text-xs text-gray-500 mt-1">Ventas y gastos del período</p>
      </div>
      
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase">Fecha</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase">Tipo</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase">Concepto</th>
              <th class="px-6 py-3 text-right text-xs font-semibold text-gray-600 uppercase">Monto</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {ventasFiltradas.slice(0, 20).map((venta) => (
              <tr key={`venta-${venta.id}`} class="hover:bg-gray-50">
                <td class="px-6 py-3 text-sm text-gray-700">{new Date(venta.fecha).toLocaleDateString('es-PE')}</td>
                <td class="px-6 py-3"><span class="px-2 py-1 text-xs rounded-full bg-green-100 text-green-700">✅ Ingreso</span></td>
                <td class="px-6 py-3 text-sm text-gray-800">{venta.producto} {venta.cantidad > 1 ? `x${venta.cantidad}` : ''}</td>
                <td class="px-6 py-3 text-sm font-semibold text-green-600 text-right">+ S/ {venta.total.toFixed(2)}</td>
              </tr>
            ))}
            {gastosFiltrados.slice(0, 20).map((gasto) => (
              <tr key={`gasto-${gasto.id}`} class="hover:bg-gray-50">
                <td class="px-6 py-3 text-sm text-gray-700">{new Date(gasto.fecha).toLocaleDateString('es-PE')}</td>
                <td class="px-6 py-3"><span class="px-2 py-1 text-xs rounded-full bg-red-100 text-red-700">❌ Egreso</span></td>
                <td class="px-6 py-3 text-sm text-gray-800">{gasto.categoria} - {gasto.descripcion}</td>
                <td class="px-6 py-3 text-sm font-semibold text-red-600 text-right">- S/ {gasto.monto.toFixed(2)}</td>
              </tr>
            ))}
            {ventasFiltradas.length === 0 && gastosFiltrados.length === 0 && (
              <tr>
                <td colspan="4" class="px-6 py-12 text-center text-gray-500">
                  <div class="text-6xl mb-3">📭</div>
                  <p>No hay transacciones en el período seleccionado</p>
                </td>
              </tr>
            )}
          </tbody>
          <tfoot class="bg-gray-50 border-t border-gray-200">
            <tr>
              <td colspan="3" class="px-6 py-3 text-right font-bold text-gray-800">Total neto:</td>
              <td class={`px-6 py-3 text-right font-bold text-lg ${gananciaNeta >= 0 ? 'text-green-600' : 'text-red-600'}`}>
                {gananciaNeta >= 0 ? '+' : ''} S/ {gananciaNeta.toFixed(2)}
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>
</Layout>