---
interface Props {
  title?: string;
}

const {
  title = "Sistema Choripanes",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <meta
      name="description"
      content="Sistema de control de gastos y ventas"
    />

    <title>{title}</title>
  </head>

  <body>
    <slot />
  </body>
</html>